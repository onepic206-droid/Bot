--=========== CONFIG ===========
local World_Name = "vvrcl|b18" 
local World_Save = "savekubreak|abangku1" 

local Seed_ID1 = 107
local Seed_ID2 = 169

local Delay_Plant = 200   
local Delay_Path = 400    
local MAX_PING = 500      
--===============================

function randomDelay(base)
    math.randomseed(os.clock() * 1000000)
    Sleep(base + math.random(-20, 50))
end

function inv(id)
    for _, item in pairs(GetInventory()) do 
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        while GetWorld().name ~= world:upper() do
            SendPacket(3, "action|join_request\nname|" .. world)
            Sleep(5000)
        end
    end
end

function faceAndPlace(x, y, id)
    local localX = GetLocal().pos.x
    local targetPixelX = x * 32
    local face = (targetPixelX > localX) and 2 or 0

    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = localX,
        y = GetLocal().pos.y,
        flags = face
    })
    randomDelay(Delay_Plant)
end

function takeSeed()
    if inv(Seed_ID1) == 0 or inv(Seed_ID2) == 0 then
        LogToConsole("Stok habis, mengambil bahan di " .. World_Save)
        warp(World_Save)
        
        local targets = {Seed_ID1, Seed_ID2}
        for _, id in ipairs(targets) do
            if inv(id) == 0 then
                for _, obj in pairs(GetObjectList()) do
                    if obj.id == id then
                        FindPath(math.floor(obj.pos.x/32), math.floor(obj.pos.y/32))
                        randomDelay(500)
                        SendPacket(2, "action|take")
                        randomDelay(800)
                        if inv(id) > 0 then break end
                    end
                end
            end
        end
        warp(World_Name)
    end
end

function isSolid(x, y)
    local t = GetTile(x, y)
    if not t then return false end
    local info = GetItemInfo(t.fg)
    -- type 0 = solid, type 18 = platform
    return (info.type == 0 or info.type == 18) and t.fg ~= 6
end

function handleSplice(x, y)
    local tile = GetTile(x, y)
    if not tile then return end

    if tile.fg == 0 then
        takeSeed()
        faceAndPlace(x, y, Seed_ID1)
        faceAndPlace(x, y, Seed_ID2)
    elseif tile.fg == Seed_ID1 then
        takeSeed()
        faceAndPlace(x, y, Seed_ID2)
    elseif tile.fg == Seed_ID2 then
        takeSeed()
        faceAndPlace(x, y, Seed_ID1)
    end
end

RunThread(function()
    LogToConsole("Script Auto Splice Started!")
    warp(World_Name)

    while true do
        local w = GetWorld()
        if not w then break end

        for y = 0, w.height - 1 do
            local startX, endX, step = 0, w.width - 1, 1
            if y % 2 == 1 then startX, endX, step = w.width - 1, 0, -1 end

            for x = startX, endX, step do
                -- Cek Ping
                if GetClient().ping >= MAX_PING then
                    while GetClient().ping >= MAX_PING do Sleep(2000) end
                end

                -- Cek Alas Tanam
                if isSolid(x, y + 1) then
                    local target = GetTile(x, y)
                    -- Pastikan kosong atau ada seed jomblo, bukan pohon (flags.tree)
                    if target and not target.flags.tree and (target.fg == 0 or target.fg == Seed_ID1 or target.fg == Seed_ID2) then
                        local px, py = math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)
                        if math.abs(px - x) > 2 or math.abs(py - y) > 2 then
                            FindPath(x, y)
                            randomDelay(100)
                        end
                        handleSplice(x, y)
                    end
                end
            end
        end
        LogToConsole("Cycle Complete. Re-scanning...")
        randomDelay(10000)
    end
end)
