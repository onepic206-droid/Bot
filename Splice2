--=========== CONFIG ===========
local seedA = 107      
local seedB = 169        
local delayTanam = 180   
local delayPath = 400    
local RANGE = 2         
local MAX_PING = 500     

local worldFarm = "WFJEW|b18"
local worldTake = "savekubreak|abangku1"
--===============================

function randomDelay(base)
    math.randomseed(os.clock() * 1000000)
    local variasi = math.random(-20, 50) 
    Sleep(base + variasi)
end

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        SendPacket(3,"action|join_request\nname|"..world)
        randomDelay(5000)
    end
end

-- ===== CEK KONSTRUKSI TILE =====
function isSolidOrPlatform(x, y)
    local tile = GetTile(x, y)
    if not tile then return false end
    
    local properties = GetItemInfo(tile.fg)
    -- Cek apakah blok tersebut solid atau tipe platform
    if properties.type == 0 or properties.type == 1 or properties.type == 18 then
        -- Abaikan jika itu Bedrock (ID 6)
        return tile.fg ~= 6
    end
    return false
end

-- ===== AMBIL STOK =====
function handleStock()
    if inv(seedA) == 0 or inv(seedB) == 0 then
        LogToConsole("Stok habis, ke gudang...")
        warp(worldTake)
        
        local idsToTake = {seedA, seedB}
        for _, id in ipairs(idsToTake) do
            if inv(id) == 0 then
                for _, obj in pairs(GetObjectList()) do
                    if obj.id == id then
                        FindPath(math.floor(obj.pos.x/32), math.floor(obj.pos.y/32), delayPath)
                        randomDelay(500)
                        SendPacket(2, "action|take")
                        randomDelay(800)
                        if inv(id) > 0 then break end
                    end
                end
            end
        end
        warp(worldFarm)
    end
end

-- ===== ANIMASI & ARAH =====
function faceAndPlace(x, y, id)
    local localX = GetLocal().pos.x
    local targetPixelX = x * 32
    local faceDirection = (targetPixelX > localX) and 2 or 0

    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = localX,
        y = GetLocal().pos.y,
        flags = faceDirection
    })
    randomDelay(delayTanam)
end

function moveAndExecute(x, y, id)
    local px, py = math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)
    if math.abs(px - x) > RANGE or math.abs(py - y) > RANGE then
        FindPath(x, y, delayPath)
        randomDelay(150)
    end
    faceAndPlace(x, y, id)
end

-- ===== LOGIKA SMART SPLICE PADA BLOK =====
function processTile(x, y)
    local tile = GetTile(x, y)
    
    -- Kita mencari blok SOLID atau PLATFORM (untuk dijadikan alas)
    if not isSolidOrPlatform(x, y) then return end

    -- Koordinat tanam adalah 1 baris di ATAS blok tersebut
    local tx, ty = x, y - 1
    local targetTile = GetTile(tx, ty)
    if not targetTile then return end

    -- Pastikan targetTile kosong atau berisi seed jomblo (BUKAN pohon/tree)
    -- Tree biasanya memiliki tipe item khusus, kita cek ID-nya
    if targetTile.fg == 0 then
        handleStock()
        moveAndExecute(tx, ty, seedA)
        moveAndExecute(tx, ty, seedB)
    elseif targetTile.fg == seedA then
        handleStock()
        moveAndExecute(tx, ty, seedB)
    elseif targetTile.fg == seedB then
        handleStock()
        moveAndExecute(tx, ty, seedA)
    end
end

-- ===== CORE LOOP =====
RunThread(function()
    warp(worldFarm)
    
    while true do
        local w = GetWorld()
        if not w then break end

        for y = 0, w.height - 1 do
            local startX, endX, step = 0, w.width - 1, 1
            if y % 2 == 1 then startX, endX, step = w.width - 1, 0, -1 end

            for x = startX, endX, step do
                -- Anti-Lag
                if GetClient().ping >= MAX_PING then
                    while GetClient().ping >= MAX_PING do Sleep(2000) end
                end

                processTile(x, y)
            end
        end
        
        LogToConsole("Siklus Splice Selesai.")
        randomDelay(10000)
    end
end)
