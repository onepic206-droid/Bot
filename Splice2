--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 210           -- Delay dasar
local RANGE = 2
local stepDelay = 400

local worldTake = "Savekubreak|abangku1"
local worldFarm = "vvrcl|b18"

-- FITUR ANTI-BAN (TAMBAHAN)
local useRandomDelay = true  -- Menambah variasi milidetik
local restEvery = 60         -- Setiap 50 kali tanam, bot akan istirahat sejenak
local restDuration = 3000    -- Istirahat selama 3 detik
local plantCount = 0
--===============================

local lastPingLog = 0
local pingLogDelay = 5000

-- ===== RANDOMIZER (Supaya pola tidak terbaca server) =====
function sleepRandom(ms)
    if useRandomDelay then
        local randomMs = math.random(ms, ms + 70) -- Menambah 0-70ms secara acak
        Sleep(randomMs)
    else
        Sleep(ms)
    end
end

-- ===== INVENTORY =====
function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

-- ===== ARAH HADAP =====
function faceTile(x)
    local px = math.floor(GetLocal().pos.x / 32)
    local flag = (x < px) and 48 or 32
    
    SendPacketRaw(false, {
        type = 0,
        state = 0,
        x = GetLocal().pos.x,
        y = GetLocal().pos.y,
        flags = flag
    })
end

-- ===== ANIMASI & PLACE =====
function spliceAnim(x, y, id)
    local px, py = GetLocal().pos.x, GetLocal().pos.y
    SendPacketRaw(false, {type = 0, state = 48, x = px, y = py, tilex = x, tiley = y})
    SendPacketRaw(false, {type = 0, state = 3120, value = id, x = px, y = py, tilex = x, tiley = y})
end

function place(x, y, id)
    faceTile(x)
    spliceAnim(x, y, id)
    SendPacketRaw(false, {
        type = 3, value = id, px = x, py = y,
        x = GetLocal().pos.x, y = GetLocal().pos.y, tilex = x, tiley = y
    })
    
    -- Hitung jumlah tanam untuk fitur istirahat
    plantCount = plantCount + 1
    if plantCount >= restEvery then
        LogToConsole("Anti-Ban: Istirahat sejenak...")
        Sleep(restDuration)
        plantCount = 0
    end
end

-- ===== SPLICE CORE =====
function splice(x, y)
    local ping = GetClient().ping
    if ping > 600 then Sleep(2000) end -- Berhenti otomatis jika lag parah (menghindari glitch)

    local px, py = math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)

    if math.abs(px-x) > RANGE or math.abs(py-y) > RANGE then
        FindPath(x, y, stepDelay)
        sleepRandom(300) 
    end

    if inv(seedA) > 0 then
        place(x, y, seedA)
        sleepRandom(delay)
    end

    if inv(seedB) > 0 then
        place(x, y, seedB)
        sleepRandom(delay)
    end
end

-- ===== TAKE SEED LOGIC (Sesuai aslimu) =====
function takeSeedID(id)
    local objs = GetObjectList()
    local bx, by = nil, nil
    local best = 999999
    local px, py = GetLocal().pos.x, GetLocal().pos.y

    for _, obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x-px)^2 + (obj.pos.y-py)^2)
            if dist < best then
                best = dist
                bx, by = math.floor(obj.pos.x/32), math.floor(obj.pos.y/32)
            end
        end
    end
    if bx then
        FindPath(bx, by, stepDelay)
        Sleep(600)
        SendPacket(2, "action|take")
        Sleep(600)
    end
end

function ambilSeed()
    LogToConsole("Anti-Ban: Menuju storage dengan pola acak...")
    warp(worldTake)
    Sleep(math.random(2000, 3500)) -- Random delay saat warp
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(500)
    end
    warp(worldFarm)
    Sleep(math.random(2000, 3000))
end

-- ===== SCANNING & ROW LOGIC =====
function canPlant(x, y)
    local t, b = GetTile(x, y), GetTile(x, y+1)
    if not t or not b then return false end
    return t.fg == 0 and b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end

function spliceRow(y)
    local w = GetWorld()
    local xs, xe, step = 0, w.width - 1, 1
    if y % 2 == 1 then xs, xe, step = w.width - 1, 0, -1 end
    
    for x = xs, xe, step do
        if inv(seedA) == 0 or inv(seedB) == 0 then ambilSeed() end
        local t = GetTile(x, y)
        if (t and (t.fg == seedA or t.fg == seedB)) or canPlant(x, y) then
            splice(x, y)
        end
    end
end

-- ===== MAIN PROGRAM =====
RunThread(function()
    math.randomseed(os.time()) -- Inisialisasi angka acak
    warp(worldFarm)
    Sleep(2000)
    
    local w = GetWorld()
    for y = 0, w.height - 1 do
        LogToConsole("Processing Row: "..y)
        spliceRow(y)
        -- Tambahan delay setiap ganti baris agar lebih natural
        Sleep(math.random(500, 1200)) 
    end
    LogToConsole("Semua Selesai, Bot Standby.")
end)
