--=========== CONFIG ===========
local seedA = 107        
local seedB = 169       
local delayTanam = 180   
local delayPath = 400    
local RANGE = 2         
local MAX_PING = 500     

local worldFarm = "WFJEW|b18"
local worldTake = "FARMLIST138|abangku1" -- World ambil seed
--===============================

function randomDelay(base)
    math.randomseed(os.clock() * 1000000)
    local variasi = math.random(-20, 50) 
    Sleep(base + variasi)
end

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        LogToConsole("Warping ke " .. world)
        SendPacket(3,"action|join_request\nname|"..world)
        randomDelay(5000)
    end
end

-- ===== FUNGSI AMBIL STOK =====
function handleStock()
    if inv(seedA) == 0 or inv(seedB) == 0 then
        LogToConsole("Stok habis, ambil bahan...")
        warp(worldTake)
        
        -- Ambil Seed A dan Seed B dari lantai
        local idsToTake = {seedA, seedB}
        for _, id in ipairs(idsToTake) do
            if inv(id) == 0 then
                for _, obj in pairs(GetObjectList()) do
                    if obj.id == id then
                        FindPath(math.floor(obj.pos.x/32), math.floor(obj.pos.y/32), delayPath)
                        randomDelay(500)
                        SendPacket(2, "action|take")
                        randomDelay(800)
                        if inv(id) > 0 then break end -- Sudah dapat, lanjut ID berikutnya
                    end
                end
            end
        end
        warp(worldFarm)
    end
end

function faceAndPlace(x, y, id)
    local localX = GetLocal().pos.x
    local targetPixelX = x * 32
    local faceDirection = (targetPixelX > localX) and 2 or 0

    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = localX,
        y = GetLocal().pos.y,
        flags = faceDirection
    })
    randomDelay(delayTanam)
end

function moveAndSplice(x, y, id)
    local px, py = math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)
    if math.abs(px - x) > RANGE or math.abs(py - y) > RANGE then
        FindPath(x, y, delayPath)
        randomDelay(100)
    end
    faceAndPlace(x, y, id)
end

function handleSplice(x, y)
    local tile = GetTile(x, y)
    if not tile then return end

    if tile.fg == 0 then
        moveAndSplice(x, y, seedA)
        moveAndSplice(x, y, seedB)
    elseif tile.fg == seedA then
        moveAndSplice(x, y, seedB)
    elseif tile.fg == seedB then
        moveAndSplice(x, y, seedA)
    end
end

-- ===== CORE LOOP =====
RunThread(function()
    warp(worldFarm)
    
    while true do
        local w = GetWorld()
        if not w then break end

        for y = 0, w.height - 1 do
            local startX, endX, step = 0, w.width - 1, 1
            if y % 2 == 1 then startX, endX, step = w.width - 1, 0, -1 end

            for x = startX, endX, step do
                -- 1. Cek Ping
                if GetClient().ping >= MAX_PING then
                    while GetClient().ping >= MAX_PING do Sleep(2000) end
                end

                -- 2. Cek apakah tile butuh ditanam/splice
                local t = GetTile(x, y)
                local b = GetTile(x, y + 1)
                
                if t and b and (t.fg == 0 or t.fg == seedA or t.fg == seedB) and (b.fg ~= 0 and b.fg ~= 6) then
                    -- 3. Cek Stok sebelum eksekusi
                    handleStock()
                    -- 4. Eksekusi Splice
                    handleSplice(x, y)
                end
            end
        end
        
        LogToConsole("World Clear / Siklus Selesai.")
        randomDelay(10000)
    end
end)
