--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 120

local worldTake = "Savekubreak|abangku1"
local listWorldFarm = {njdoJ|abangku1",
"vujxB|abangku1",
"vujxC|abangku1",
"vujxG|abangku1",
"vujxL|abangku1"}

local PING_LIMIT = 500
--===============================

-- ===== CEK PING =====
function waitPingStable()
    while GetClient().ping > PING_LIMIT do
        LogToConsole("Ping tinggi ("..GetClient().ping..") -> menunggu")
        Sleep(500)
    end
end

function getPosTile()
    return math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)
end

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        LogToConsole("Warping to " .. world)
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(6000)
    end
end

function waitPlaced(x,y)
    for i = 1,10 do
        local t = GetTile(x,y)
        if t and t.fg ~= 0 then return true end
        Sleep(120)
    end
    return false
end

function place(x,y,id)
    waitPingStable()
    -- Face tile logic
    local px = math.floor(GetLocal().pos.x/32)
    if x > px then SendPacketRaw(false,{type=0,state=16})
    elseif x < px then SendPacketRaw(false,{type=0,state=48}) end
    
    Sleep(100)
    SendPacketRaw(false,{
        type = 3, value = id, px = x, py = y,
        x = GetLocal().pos.x, y = GetLocal().pos.y
    })
    Sleep(50)
end

function splice(x,y)
    local px,py = getPosTile()
    if px ~= x or py ~= y then
        FindPath(x,y,400)
        Sleep(250)
    end

    local t = GetTile(x,y)
    -- Jika tile kosong, taruh seedA
    if t and t.fg == 0 then
        if inv(seedA) > 0 then
            place(x,y,seedA)
            waitPlaced(x,y)
            Sleep(delay)
        end
    end

    -- Timpa dengan bahan satunya (splice)
    t = GetTile(x,y)
    if t and (t.fg == seedA or t.fg == seedB) then
        local toPlace = (t.fg == seedA) and seedB or seedA
        if inv(toPlace) > 0 then
            place(x,y,toPlace)
            Sleep(delay)
        end
    end
end

function canPlant(x,y)
    local t = GetTile(x,y)
    local b = GetTile(x,y+1)
    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    return b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end

function takeSeedID(id)
    local objs = GetObjectList()
    local bx,by = nil,nil
    local px, py = GetLocal().pos.x, GetLocal().pos.y
    local best = 99999
    
    for _,obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x-px)^2 + (obj.pos.y-py)^2)
            if dist < best then
                best = dist
                bx, by = math.floor(obj.pos.x/32), math.floor(obj.pos.y/32)
            end
        end
    end

    if bx then
        FindPath(bx,by,400)
        Sleep(200)
        SendPacket(2,"action|take")
        Sleep(450)
    end
end

function cekSeedSmart(currentWorld)
    if inv(seedA) == 0 or inv(seedB) == 0 then
        LogToConsole("Bahan habis -> Restock")
        warp(worldTake)
        while inv(seedA) == 0 or inv(seedB) == 0 do
            if inv(seedA) == 0 then takeSeedID(seedA) end
            if inv(seedB) == 0 then takeSeedID(seedB) end
            Sleep(500)
        end
        warp(currentWorld)
        Sleep(2000)
    end
end

function spliceLeftover()
    local w = GetWorld()
    for y = 0, w.height-1 do
        for x = 0, w.width-1 do
            local t = GetTile(x,y)
            if t and (t.fg == seedA or t.fg == seedB) then
                splice(x,y)
            end
        end
    end
end

function isWorldFull()
    local w = GetWorld()
    for y = 0, w.height - 1 do
        for x = 0, w.width - 1 do
            if canPlant(x,y) then return false end
            local t = GetTile(x,y)
            if t and (t.fg == seedA or t.fg == seedB) then return false end
        end
    end
    return true
end

-- ===== MAIN =====
RunThread(function()
    while true do
        for _, targetWorld in ipairs(listWorldFarm) do
            warp(targetWorld)
            Sleep(2000)

            -- Cek sisa seed yang belum di-splice saat masuk world
            cekSeedSmart(targetWorld)
            spliceLeftover()

            -- Tanam per baris
            local w = GetWorld()
            for y = 0, w.height-1 do
                if isWorldFull() then break end
                
                local xs,xe,step = 0,w.width-1,1
                if y % 2 == 1 then xs,xe,step = w.width-1,0,-1 end
                
                local x = xs
                while (step==1 and x<=xe) or (step==-1 and x>=xe) do
                    cekSeedSmart(targetWorld)
                    
                    if canPlant(x,y) or (GetTile(x,y).fg == seedA or GetTile(x,y).fg == seedB) then
                        splice(x,y)
                    end
                    x = x + step
                end
            end
            
            LogToConsole(targetWorld .. " full. Lanjut world berikutnya.")
        end
        LogToConsole("Semua world selesai. Ulangi list.")
    end
end)
