--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 150

local worldTake = "Savekubreak|abangku1"

-- Daftar world farm (Index) - Tambahkan sesukamu
local worldFarmList = {
  "njdoJ|abangku1",
"vujxB|abangku1",
"vujxC|abangku1",
"vujxG|abangku1",
"vujxL|abangku1",
}

local currentWorldIndex = 1
local PING_LIMIT = 500
--===============================


-- ===== CEK PING =====
function waitPingStable()
    while GetClient().ping > PING_LIMIT do
        LogToConsole("Ping tinggi ("..GetClient().ping..") → menunggu")
        Sleep(500)
    end
end


-- ===== POSISI TILE PLAYER =====
function getPosTile()
    return math.floor(GetLocal().pos.x/32),
           math.floor(GetLocal().pos.y/32)
end


-- ===== SMOOTH PATH (GERAK HALUS) =====
function smoothPath(tx,ty)
    local px,py = getPosTile()
    while px ~= tx or py ~= ty do
        if px < tx then px = px + 1
        elseif px > tx then px = px - 1 end
        if py < ty then py = py + 1
        elseif py > ty then py = py - 1 end
        FindPath(px,py,50)
        Sleep(90)
    end
end


-- ===== HADAP TILE =====
function faceTile(x)
    local px = math.floor(GetLocal().pos.x/32)
    if x > px then
        SendPacketRaw(false,{type=0,state=16})
    elseif x < px then
        SendPacketRaw(false,{type=0,state=48})
    end
end


-- ===== INVENTORY =====
function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then
            return item.amount
        end
    end
    return 0
end


-- ===== WARP =====
function warp(world)
    local target = world:upper()
    while GetWorld().name ~= target do
        LogToConsole("Warping ke: " .. target)
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(6000)
    end
end


-- ===== CEK TILE SUDAH KE-PLACE =====
function waitPlaced(x,y)
    for i = 1,10 do
        local t = GetTile(x,y)
        if t and t.fg ~= 0 then
            return true
        end
        Sleep(120)
    end
    return false
end


-- ===== PLACE =====
function place(x,y,id)
    waitPingStable()
    faceTile(x)
    Sleep(100)
    SendPacketRaw(false,{
        type = 3,
        value = id,
        px = x,
        py = y,
        x = GetLocal().pos.x,
        y = GetLocal().pos.y
    })
    Sleep(50)
end


-- ===== SPLICE (REVISI PATH) =====
function splice(x,y)
    waitPingStable()
    local px,py = getPosTile()
    if px ~= x or py ~= y then
        FindPath(x,y,400)
        Sleep(250)
    end
    if inv(seedA) > 0 then
        place(x,y,seedA)
        waitPlaced(x,y)
        Sleep(delay)
    end
    if inv(seedB) > 0 then
        place(x,y,seedB)
        waitPlaced(x,y)
        Sleep(delay)
    end
end


-- ===== CEK TANAM =====
function canPlant(x,y)
    local t = GetTile(x,y)
    local b = GetTile(x,y+1)
    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    return b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end


-- ===== FIND FLOATING TERDEKAT =====
function findNearestObject(id)
    local objs = GetObjectList()
    local best = 99999
    local bx,by = nil,nil
    local px = GetLocal().pos.x
    local py = GetLocal().pos.y
    for _,obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x-px)^2 + (obj.pos.y-py)^2)
            if dist < best then
                best = dist
                bx = math.floor(obj.pos.x/32)
                by = math.floor(obj.pos.y/32)
            end
        end
    end
    return bx,by
end


-- ===== TAKE SEED =====
function takeSeedID(id)
    waitPingStable()
    local x,y = findNearestObject(id)
    if x then
        FindPath(x,y,400)
        Sleep(200)
        SendPacket(2,"action|take")
        Sleep(450)
    end
end


-- ===== AMBIL SEED =====
function ambilSeed()
    LogToConsole("Seed habis → ke TAKE")
    warp(worldTake)
    Sleep(1000)
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(300)
    end
    LogToConsole("Seed dapat → balik FARM Index: " .. currentWorldIndex)
    warp(worldFarmList[currentWorldIndex])
    Sleep(1000)
    -- Setelah balik dari ambil seed, cek lagi sisaan di world tersebut
    spliceLeftover()
end


function cekSeedSmart()
    if inv(seedA) == 0 or inv(seedB) == 0 then
        ambilSeed()
    end
end


-- ===== SPLICE LEFTOVER =====
function spliceLeftover()
    local w = GetWorld()
    LogToConsole("Scanning sisa seed (Leftover)...")
    for y = 0, w.height-1 do
        for x = 0, w.width-1 do
            local t = GetTile(x,y)
            -- Cek jika ada seed yang sudah ter-place tapi belum ter-splice
            if t and (t.fg == seedA or t.fg == seedB) then
                splice(x,y)
            end
        end
    end
end


-- ===== SPLICE PER ROW =====
function spliceRow(y)
    local w = GetWorld()
    local xs,xe,step = 0,w.width-1,1
    if y % 2 == 1 then xs,xe,step = w.width-1,0,-1 end
    local x = xs
    while (step==1 and x<=xe) or (step==-1 and x>=xe) do
        cekSeedSmart()
        local t = GetTile(x,y)
        if t and (t.fg == seedA or t.fg == seedB) then
            splice(x,y)
        end
        if canPlant(x,y) then
            splice(x,y)
        end
        x = x + step
    end
end

-- ===== SCAN ULANG WORLD =====
function isWorldClear()
    local w = GetWorld()
    for y = 0, w.height-1 do
        for x = 0, w.width-1 do
            if canPlant(x,y) then return false end
            local t = GetTile(x,y)
            if t and (t.fg == seedA or t.fg == seedB) then return false end
        end
    end
    return true
end


-- ===== MAIN =====
RunThread(function()

    while true do
        
        local currentWorld = worldFarmList[currentWorldIndex]
        warp(currentWorld)
        Sleep(2000)

        LogToConsole("Memulai Farm di: " .. currentWorld)

        -- [NEW FEATURE] CEK SISAAN BEGITU JOIN WORLD
        spliceLeftover()

        -- Cycle Utama Tanam Per Baris
        local w = GetWorld()
        for y = 0, w.height-1 do
            spliceRow(y)
        end

        -- Pastikan semua sisa (leftover) yang mungkin muncul belakangan tetap bersih
        spliceLeftover()

        -- Cek apakah world benar-benar clear sebelum pindah index
        if isWorldClear() then
            LogToConsole("World " .. currentWorld .. " SELESAI!")
            currentWorldIndex = currentWorldIndex + 1
            
            -- Jika semua world selesai, kembali ke Index 1
            if currentWorldIndex > #worldFarmList then
                LogToConsole("Semua World Index Selesai. Mengulang dari Index 1.")
                currentWorldIndex = 1
            end
        else
            LogToConsole("Masih ada sisa/pohon belum tumbuh di " .. currentWorld .. ". Scan ulang...")
            -- Index tidak ditambah, jadi loop akan mengulang di world yang sama
        end

        Sleep(1000)
    end

end)
