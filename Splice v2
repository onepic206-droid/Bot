
--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 120

local worldTake = {"Savekubreak|abangku1"}
local worldFarm = {
"njdoJ|abangku1",
"vujxB|abangku1",
"vujxC|abangku1",
"vujxG|abangku1",
"vujxL|abangku1",
"vujxM|abangku1",
"vujxN|abangku1",
}  -- Multi world farm

local PING_LIMIT = 500
--===============================


-- ===== CEK PING =====
function waitPingStable()
    while GetClient().ping > PING_LIMIT do
        LogToConsole("Ping tinggi ("..GetClient().ping..") → menunggu")
        Sleep(500)
    end
end


-- ===== POSISI TILE PLAYER =====
function getPosTile()
    return math.floor(GetLocal().pos.x/32),
           math.floor(GetLocal().pos.y/32)
end


-- ===== SMOOTH WALK =====
function smoothWalk(tx, ty)
    local px, py = getPosTile()
    local maxStep = 80
    local step = 0

    while (px ~= tx or py ~= ty) and step < maxStep do
        local nx, ny = px, py

        if px < tx then nx = px + 1
        elseif px > tx then nx = px - 1 end

        if py < ty then ny = py + 1
        elseif py > ty then ny = py - 1 end

        FindPath(nx, ny, 50)
        Sleep(100)

        local newx, newy = getPosTile()
        if newx == px and newy == py then
            FindPath(nx + 1, ny, 50)
            Sleep(80)
            FindPath(nx, ny + 1, 50)
            Sleep(80)
        end

        px, py = getPosTile()
        step = step + 1
    end
end


-- ===== HADAP TILE =====
function faceTile(x)
    local px = math.floor(GetLocal().pos.x/32)
    if x > px then
        SendPacketRaw(false, {type=0, state=16})
    elseif x < px then
        SendPacketRaw(false, {type=0, state=48})
    end
end


-- ===== INVENTORY =====
function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then
            return item.amount
        end
    end
    return 0
end


-- ===== WARP =====
function warp(world)
    local name = world:match("^([^|]+)"):upper()
    if GetWorld().name ~= name then
        SendPacket(3, "action|join_request\nname|"..world)
        Sleep(6000)
    end
end


-- ===== CEK TILE SUDAH KE-PLACE =====
function waitPlaced(x, y)
    for i = 1, 10 do
        local t = GetTile(x, y)
        if t and t.fg ~= 0 then
            return true
        end
        Sleep(120)
    end
    return false
end


-- ===== PLACE =====
function place(x, y, id)
    waitPingStable()
    faceTile(x)
    Sleep(100)
    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = GetLocal().pos.x,
        y = GetLocal().pos.y
    })
    Sleep(50)
end


-- ===== FIND FLOATING TERDEKAT =====
function findNearestObject(id)
    local objs = GetObjectList()
    local best = 99999
    local bx, by = nil, nil
    local px = GetLocal().pos.x
    local py = GetLocal().pos.y

    for _, obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x - px)^2 + (obj.pos.y - py)^2)
            if dist < best then
                best = dist
                bx = math.floor(obj.pos.x / 32)
                by = math.floor(obj.pos.y / 32)
            end
        end
    end

    return bx, by
end


-- ===== TAKE SEED =====
function takeSeedID(id)
    waitPingStable()

    local x, y = findNearestObject(id)
    if not x then return end

    smoothWalk(x, y)
    Sleep(150)

    SendPacket(2, "action|take")
    Sleep(450)

    if inv(id) == 0 then
        LogToConsole("Take gagal → coba geser kanan")
        smoothWalk(x + 1, y)
        Sleep(100)
        SendPacket(2, "action|take")
        Sleep(400)
    end

    if inv(id) == 0 then
        LogToConsole("Take gagal → coba geser kiri")
        smoothWalk(x - 1, y)
        Sleep(100)
        SendPacket(2, "action|take")
        Sleep(400)
    end

    if inv(id) == 0 then
        LogToConsole("Take gagal → coba tile bawah")
        smoothWalk(x, y + 1)
        Sleep(100)
        SendPacket(2, "action|take")
        Sleep(400)
    end
end


-- ===== AMBIL SEED (MULTI WORLD TAKE) =====
function ambilSeed(currentFarmWorld)
    LogToConsole("Seed habis → ke TAKE")

    local taken = false

    for _, wt in ipairs(worldTake) do
        warp(wt)
        Sleep(1500)

        local maxTry = 15
        local tries = 0

        while (inv(seedA) == 0 or inv(seedB) == 0) and tries < maxTry do
            if inv(seedA) == 0 then takeSeedID(seedA) end
            if inv(seedB) == 0 then takeSeedID(seedB) end
            Sleep(300)
            tries = tries + 1
        end

        if inv(seedA) > 0 and inv(seedB) > 0 then
            LogToConsole("Seed dapat dari "..wt)
            taken = true
            break
        else
            LogToConsole("Seed tidak cukup di "..wt.." → coba world berikutnya")
        end
    end

    if not taken then
        LogToConsole("Semua world take sudah dicoba, seed tetap kurang!")
    end

    LogToConsole("Balik ke FARM: "..currentFarmWorld)
    warp(currentFarmWorld)
    Sleep(1500)

    spliceLeftover()
end


function cekSeedSmart(currentFarmWorld)
    if inv(seedA) == 0 or inv(seedB) == 0 then
        ambilSeed(currentFarmWorld)
    end
end


-- ===== CEK TANAM =====
function canPlant(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)
    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    return b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end


-- ===== SPLICE =====
function splice(x, y, currentFarmWorld)
    waitPingStable()

    smoothWalk(x, y)
    Sleep(100)

    if inv(seedA) > 0 then
        place(x, y, seedA)
        waitPlaced(x, y)
        Sleep(delay)
    end

    if inv(seedB) > 0 then
        place(x, y, seedB)
        waitPlaced(x, y)
        Sleep(delay)
    end
end


-- ===== SPLICE LEFTOVER =====
function spliceLeftover(currentFarmWorld)
    local w = GetWorld()

    for y = 0, w.height - 1 do
        for x = 0, w.width - 1 do
            local t = GetTile(x, y)
            if t and (t.fg == seedA or t.fg == seedB) then
                splice(x, y, currentFarmWorld)
            end
        end
    end
end


-- ===== CEK APAKAH SEMUA TILE SUDAH TERSPLICE =====
function allSpliced()
    local w = GetWorld()

    for y = 0, w.height - 1 do
        for x = 0, w.width - 1 do
            if canPlant(x, y) then
                return false
            end
            local t = GetTile(x, y)
            if t and (t.fg == seedA or t.fg == seedB) then
                return false
            end
        end
    end

    return true
end


-- ===== SPLICE PER ROW =====
function spliceRow(y, currentFarmWorld)
    local w = GetWorld()

    local xs, xe, step = 0, w.width - 1, 1
    if y % 2 == 1 then xs, xe, step = w.width - 1, 0, -1 end

    local x = xs

    while (step == 1 and x <= xe) or (step == -1 and x >= xe) do

        cekSeedSmart(currentFarmWorld)

        local t = GetTile(x, y)

        if t and (t.fg == seedA or t.fg == seedB) then
            splice(x, y, currentFarmWorld)
        end

        if canPlant(x, y) then
            splice(x, y, currentFarmWorld)
        end

        x = x + step
    end
end


-- ===== FARM SATU WORLD =====
function farmWorld(farmWorld)
    LogToConsole("Mulai farm di: "..farmWorld)
    warp(farmWorld)
    Sleep(1500)

    cekSeedSmart(farmWorld)
    spliceLeftover(farmWorld)

    local w = GetWorld()

    for y = 0, w.height - 1 do
        spliceRow(y, farmWorld)
    end

    if allSpliced() then
        LogToConsole("World "..farmWorld.." selesai tersplice!")
        return true  -- world ini selesai
    end

    return false  -- belum selesai
end


-- ===== MAIN =====
RunThread(function()

    while true do
        local allDone = true

        for _, fw in ipairs(worldFarm) do
            local done = farmWorld(fw)
            if not done then
                allDone = false
            end
        end

        if allDone then
            LogToConsole("Semua world farm sudah tersplice → Script berhenti!")
            break
        end

        LogToConsole("1 Full Cycle selesai → ulangi semua world farm")
        Sleep(500)
    end

end)
