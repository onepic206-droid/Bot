--=========== CONFIG ===========
local seedA = 111
local seedB = 231
local delay = 180

local worldTake = "savekubreak|abangku1"
local worldFarm = "vujxg|abangku1"

local PING_LIMIT = 500
local WARP_DELAY = 7000
local PATH_DELAY = 200
local PLACE_DELAY = 180
local TAKE_DELAY = 350
local LOOP_DELAY = 5000

local PLACE_RANGE = 3
local LEFTOVER_INTERVAL = 180000 -- 3 menit
--===============================

-- ===== TIMER =====
local lastLeftoverCheck = 0

-- ===== PARSE WORLD|DOOR =====
function parseWorld(str)
    local world, door = str:match("([^|]+)|?(.*)")
    return (world or ""):upper(), door or ""
end

local FARM_WORLD, FARM_DOOR = parseWorld(worldFarm)
local TAKE_WORLD, TAKE_DOOR = parseWorld(worldTake)

-- ===== WORLD INFO =====
function getWorldName()
    local w = GetWorld()
    return w and w.name and w.name:upper() or ""
end

function inWorld(target)
    local world, _ = parseWorld(target)
    return getWorldName() == world
end

-- ===== CEK PING =====
function getPing()
    local cl = GetClient()
    if not cl then return 9999 end
    return cl.ping or 9999
end

function waitPingStable()
    local warned = false

    while true do
        local ping = getPing()

        if ping <= PING_LIMIT then
            if warned then
                LogToConsole("Ping stabil lagi (" .. ping .. ")")
            end
            return true
        end

        if not warned then
            LogToConsole("Ping tinggi (" .. ping .. ") -> menunggu stabil")
            warned = true
        else
            LogToConsole("Masih lag (" .. ping .. ") -> hold")
        end

        Sleep(500)
    end
end

-- ===== POSISI TILE PLAYER =====
function getPosTile()
    local me = GetLocal()
    if not me then return -1, -1 end
    return math.floor(me.pos.x / 32), math.floor(me.pos.y / 32)
end

-- ===== HADAP TILE =====
function faceTile(x)
    local me = GetLocal()
    if not me then return end

    local px = math.floor(me.pos.x / 32)

    if x > px then
        SendPacketRaw(false, {type = 0, state = 16})
    elseif x < px then
        SendPacketRaw(false, {type = 0, state = 48})
    end
end

-- ===== INVENTORY =====
function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then
            return item.amount
        end
    end
    return 0
end

-- ===== WARP =====
function warp(target)
    waitPingStable()

    local world, door = parseWorld(target)
    local current = getWorldName()

    if current ~= world then
        LogToConsole("Warp -> " .. world .. (door ~= "" and ("|" .. door) or ""))

        if door ~= "" then
            SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
        else
            RequestJoinWorld(world)
        end

        Sleep(WARP_DELAY)
    end

    local tries = 0
    while getWorldName() ~= world and tries < 5 do
        waitPingStable()
        LogToConsole("Belum masuk " .. world .. " -> retry warp")

        if door ~= "" then
            SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
        else
            RequestJoinWorld(world)
        end

        Sleep(WARP_DELAY)
        tries = tries + 1
    end

    return getWorldName() == world
end

-- ===== REJOIN WORLD =====
function rejoinWorld(target)
    local world, door = parseWorld(target)

    LogToConsole("Rejoin -> " .. world .. (door ~= "" and ("|" .. door) or ""))

    waitPingStable()

    if door ~= "" then
        SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
    else
        RequestJoinWorld(world)
    end

    Sleep(WARP_DELAY)
    return getWorldName() == world
end

-- ===== CEK TILE =====
function isSolidForPlant(fg)
    if fg == 0 then return false end
    if fg == 6 then return false end
    return fg % 2 == 0
end

function canPlant(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)

    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    if not isSolidForPlant(b.fg) then return false end

    return true
end

function isHalfSpliceTile(x, y)
    local t = GetTile(x, y)
    if not t then return false end
    return t.fg == seedA or t.fg == seedB
end

function isTargetNeedSplice(x, y)
    return canPlant(x, y) or isHalfSpliceTile(x, y)
end

function canStandAt(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)

    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    if b.fg == 0 then return false end
    return true
end

-- ===== CEK RANGE PLACE =====
function inPlaceRange(x, y)
    local px, py = getPosTile()
    if px == -1 then return false end

    local dx = math.abs(px - x)
    local dy = math.abs(py - y)

    return dx <= PLACE_RANGE and dy <= 1
end

function getBestStandTile(tx, ty)
    local candidates = {}

    for dist = 1, PLACE_RANGE do
        table.insert(candidates, {x = tx - dist, y = ty})
        table.insert(candidates, {x = tx + dist, y = ty})
    end

    table.insert(candidates, {x = tx, y = ty - 1})
    table.insert(candidates, {x = tx, y = ty + 1})

    local px, py = getPosTile()
    local best = nil
    local bestScore = 999999

    for _, c in pairs(candidates) do
        if canStandAt(c.x, c.y) then
            local score = math.abs(c.x - px) + math.abs(c.y - py)
            if score < bestScore then
                bestScore = score
                best = c
            end
        end
    end

    return best
end

-- ===== WAIT TILE BERUBAH =====
function waitPlacedOrChanged(x, y, oldFg)
    local tries = 0

    while tries < 10 do
        waitPingStable()
        Sleep(PLACE_DELAY)

        local t = GetTile(x, y)
        if t and t.fg ~= oldFg then
            return true
        end

        tries = tries + 1
    end

    return false
end

-- ===== PATH AMAN =====
function safeFindPath(x, y, targetWorld)
    waitPingStable()

    if targetWorld and not inWorld(targetWorld) then
        warp(targetWorld)
        Sleep(800)
    end

    waitPingStable()
    FindPath(x, y, 400)
    Sleep(PATH_DELAY)
    waitPingStable()

    local px, py = getPosTile()
    if px == x and py == y then
        return true
    end

    LogToConsole("FindPath gagal ke " .. x .. "," .. y .. " -> rejoin world")

    if targetWorld then
        rejoinWorld(targetWorld)
        Sleep(800)
    end

    waitPingStable()
    FindPath(x, y, 400)
    Sleep(PATH_DELAY)
    waitPingStable()

    px, py = getPosTile()
    return px == x and py == y
end

function ensurePlacePosition(tx, ty, targetWorld)
    if inPlaceRange(tx, ty) then
        return true
    end

    local stand = getBestStandTile(tx, ty)
    if not stand then
        LogToConsole("Tidak ada posisi berdiri valid dekat target: " .. tx .. "," .. ty)
        return false
    end

    local moved = safeFindPath(stand.x, stand.y, targetWorld)
    if not moved then
        return false
    end

    return inPlaceRange(tx, ty)
end

-- ===== PLACE =====
function place(x, y, id)
    waitPingStable()

    if not ensurePlacePosition(x, y, worldFarm) then
        return false
    end

    local me = GetLocal()
    if not me then return false end

    faceTile(x)
    Sleep(50)
    waitPingStable()

    me = GetLocal()
    if not me then return false end

    local px = math.floor(me.pos.x / 32)
    local state = 16
    if x < px then
        state = 48
    end

    local t = GetTile(x, y)
    local oldFg = t and t.fg or 0

    SendPacketRaw(false, {
        type = 3,
        state = state,
        value = id,
        px = x,
        py = y,
        x = me.pos.x,
        y = me.pos.y
    })

    return waitPlacedOrChanged(x, y, oldFg)
end

-- ===== FIND FLOATING TERDEKAT =====
function findNearestObject(id)
    local objs = GetObjectList()
    local me = GetLocal()
    if not me or not objs then return nil, nil end

    local best = 999999
    local bx, by = nil, nil

    local px = me.pos.x
    local py = me.pos.y

    for _, obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x - px)^2 + (obj.pos.y - py)^2)

            if dist < best then
                best = dist
                bx = math.floor(obj.pos.x / 32)
                by = math.floor(obj.pos.y / 32)
            end
        end
    end

    return bx, by
end

-- ===== TAKE SEED FLOATING =====
function takeSeedID(id)
    waitPingStable()

    local x, y = findNearestObject(id)
    if x and y then
        local moved = safeFindPath(x, y, worldTake)
        if not moved then
            return false
        end

        Sleep(150)
        waitPingStable()

        SendPacket(2, "action|take")
        Sleep(TAKE_DELAY)
        return true
    end

    return false
end

-- ===== SPLICE SATU TILE =====
function splice(x, y)
    if not inWorld(worldFarm) then
        warp(worldFarm)
        Sleep(700)
    end

    waitPingStable()

    if not ensurePlacePosition(x, y, worldFarm) then
        LogToConsole("Gagal ambil posisi place untuk: " .. x .. "," .. y)
        return false
    end

    local t = GetTile(x, y)
    if not t then return false end

    -- tile kosong valid -> place seedA lalu seedB
    if t.fg == 0 then
        if not canPlant(x, y) then
            return false
        end

        if inv(seedA) > 0 then
            place(x, y, seedA)
            Sleep(delay)
        else
            return false
        end

        waitPingStable()
        t = GetTile(x, y)
        if not t then return false end

        if (t.fg == seedA or t.fg == seedB) and inv(seedB) > 0 then
            place(x, y, seedB)
            Sleep(delay)
            return true
        end

        return t.fg ~= 0
    end

    -- tile setengah splice
    if t.fg == seedA or t.fg == seedB then
        local before = t.fg

        if before == seedA then
            if inv(seedB) <= 0 then return false end
            place(x, y, seedB)
            Sleep(delay)
            return true
        elseif before == seedB then
            if inv(seedA) <= 0 then return false end
            place(x, y, seedA)
            Sleep(delay)
            return true
        end
    end

    return false
end

-- ===== AMBIL SEED =====
function ambilSeed()
    LogToConsole("Seed habis -> ke TAKE")

    warp(worldTake)
    Sleep(700)

    while inv(seedA) == 0 or inv(seedB) == 0 do
        waitPingStable()

        if not inWorld(worldTake) then
            warp(worldTake)
            Sleep(700)
        end

        if inv(seedA) == 0 then
            takeSeedID(seedA)
        end

        if inv(seedB) == 0 then
            takeSeedID(seedB)
        end

        Sleep(250)
    end

    LogToConsole("Seed dapat -> balik FARM")

    warp(worldFarm)
    Sleep(1000)

    while not inWorld(worldFarm) do
        LogToConsole("Belum masuk FARM -> retry")
        warp(worldFarm)
        Sleep(1000)
    end

    waitPingStable()
end

function cekSeedSmart()
    if inv(seedA) == 0 or inv(seedB) == 0 then
        ambilSeed()
    end
end

-- ===== SPLICE LEFTOVER =====
function spliceLeftover()
    if not inWorld(worldFarm) then
        warp(worldFarm)
        Sleep(700)
    end

    local w = GetWorld()
    if not w then return false end

    LogToConsole("Mulai spliceLeftover")
    local found = false

    for pass = 1, 3 do
        local didSomething = false

        for y = 0, w.height - 1 do
            for x = 0, w.width - 1 do
                waitPingStable()

                if not inWorld(worldFarm) then
                    warp(worldFarm)
                    Sleep(700)
                    w = GetWorld()
                    if not w then return found end
                end

                local t = GetTile(x, y)

                if t then
                    local need =
                        canPlant(x, y) or
                        t.fg == seedA or
                        t.fg == seedB

                    if need then
                        cekSeedSmart()

                        local t2 = GetTile(x, y)
                        if t2 then
                            local need2 =
                                canPlant(x, y) or
                                t2.fg == seedA or
                                t2.fg == seedB

                            if need2 then
                                if splice(x, y) then
                                    didSomething = true
                                    found = true
                                end
                            end
                        end
                    end
                end
            end
        end

        if not didSomething then
            break
        end
    end

    lastLeftoverCheck = os.time() * 1000
    LogToConsole("Selesai spliceLeftover")
    return found
end

function shouldRunLeftover()
    local now = os.time() * 1000
    if lastLeftoverCheck == 0 then
        return true
    end
    return (now - lastLeftoverCheck) >= LEFTOVER_INTERVAL
end

-- ===== SPLICE PER ROW =====
function spliceRow(y)
    local w = GetWorld()
    if not w then return end

    local xs, xe, step = 0, w.width - 1, 1
    if y % 2 == 1 then
        xs, xe, step = w.width - 1, 0, -1
    end

    local x = xs

    while (step == 1 and x <= xe) or (step == -1 and x >= xe) do
        waitPingStable()
        cekSeedSmart()

        if shouldRunLeftover() then
            spliceLeftover()
        end

        if not inWorld(worldFarm) then
            warp(worldFarm)
            Sleep(700)
        end

        local t = GetTile(x, y)

        if t then
            if t.fg == seedA or t.fg == seedB then
                splice(x, y)
            elseif canPlant(x, y) then
                splice(x, y)
            end
        end

        x = x + step
    end
end

