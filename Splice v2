--=========== CONFIG ===========
local seedA = 111
local seedB = 231
local delay = 180

local worldTake = "savekubreak|abangku1"
local worldFarm = "vujxg|abangku1"

local PING_LIMIT = 500
local WARP_DELAY = 7000
local PATH_DELAY = 200
local PLACE_DELAY = 180
local TAKE_DELAY = 350
local LOOP_DELAY = 5000

local PLANT_RANGE = 3
--===============================


-- ===== PARSE WORLD|DOOR =====
function parseWorld(str)
    local world, door = str:match("([^|]+)|?(.*)")
    return (world or ""):upper(), door or ""
end

local FARM_WORLD, FARM_DOOR = parseWorld(worldFarm)
local TAKE_WORLD, TAKE_DOOR = parseWorld(worldTake)


-- ===== WORLD INFO =====
function getWorldName()
    local w = GetWorld()
    return w and w.name and w.name:upper() or ""
end

function inWorld(target)
    local world, _ = parseWorld(target)
    return getWorldName() == world
end


-- ===== CEK PING =====
function getPing()
    local cl = GetClient()
    if not cl then return 9999 end
    return cl.ping or 9999
end

function waitPingStable()
    local warned = false

    while true do
        local ping = getPing()

        if ping <= PING_LIMIT then
            if warned then
                LogToConsole("Ping stabil lagi (" .. ping .. ")")
            end
            return true
        end

        if not warned then
            LogToConsole("Ping tinggi (" .. ping .. ") -> menunggu stabil")
            warned = true
        else
            LogToConsole("Masih lag (" .. ping .. ") -> hold")
        end

        Sleep(500)
    end
end


-- ===== POSISI TILE PLAYER =====
function getPosTile()
    local me = GetLocal()
    if not me then return -1, -1 end
    return math.floor(me.pos.x / 32), math.floor(me.pos.y / 32)
end


-- ===== HADAP TILE =====
function faceTile(x)
    local me = GetLocal()
    if not me then return end

    local px = math.floor(me.pos.x / 32)

    if x > px then
        SendPacketRaw(false, {type = 0, state = 16})
    elseif x < px then
        SendPacketRaw(false, {type = 0, state = 48})
    end
end


-- ===== INVENTORY =====
function inv(id)
    local items = GetInventory()
    if not items then return 0 end

    for _, item in pairs(items) do
        if item.id == id then
            return item.amount
        end
    end
    return 0
end


-- ===== WARP =====
function warp(target)
    waitPingStable()

    local world, door = parseWorld(target)
    local current = getWorldName()

    if current ~= world then
        LogToConsole("Warp -> " .. world .. (door ~= "" and ("|" .. door) or ""))

        if door ~= "" then
            SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
        else
            RequestJoinWorld(world)
        end

        Sleep(WARP_DELAY)
    end

    local tries = 0
    while getWorldName() ~= world and tries < 5 do
        waitPingStable()
        LogToConsole("Belum masuk " .. world .. " -> retry warp")

        if door ~= "" then
            SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
        else
            RequestJoinWorld(world)
        end

        Sleep(WARP_DELAY)
        tries = tries + 1
    end

    return getWorldName() == world
end


-- ===== REJOIN WORLD =====
function rejoinWorld(target)
    local world, door = parseWorld(target)

    LogToConsole("Rejoin -> " .. world .. (door ~= "" and ("|" .. door) or ""))

    waitPingStable()

    if door ~= "" then
        SendPacket(3, "action|join_request\nname|" .. world .. "|" .. door .. "\ninvitedWorld|0")
    else
        RequestJoinWorld(world)
    end

    Sleep(WARP_DELAY)
    return getWorldName() == world
end


-- ===== VALIDASI TILE =====
function isSolidTile(fg)
    if fg == 0 then return false end
    if fg == 6 then return false end
    return fg % 2 == 0
end

function canPlant(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)

    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    if not isSolidTile(b.fg) then return false end

    return true
end

function canStandAt(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)

    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    if b.fg == 0 then return false end

    return true
end

function inPlantRangeFrom(px, py, tx, ty)
    return math.abs(px - tx) <= PLANT_RANGE and math.abs(py - ty) <= PLANT_RANGE
end

function inPlantRange(tx, ty)
    local px, py = getPosTile()
    return inPlantRangeFrom(px, py, tx, ty)
end


-- ===== CARI TILE BERDIRI TERBAIK UNTUK PLACE TARGET =====
function findStandTileForTarget(tx, ty)
    local w = GetWorld()
    if not w then return nil, nil end

    local me = GetLocal()
    if not me then return nil, nil end

    local px = math.floor(me.pos.x / 32)
    local py = math.floor(me.pos.y / 32)

    local bestScore = 999999
    local bestX, bestY = nil, nil

    for y = math.max(0, ty - PLANT_RANGE), math.min(w.height - 2, ty + PLANT_RANGE) do
        for x = math.max(0, tx - PLANT_RANGE), math.min(w.width - 1, tx + PLANT_RANGE) do
            if not (x == tx and y == ty) then
                if canStandAt(x, y) and inPlantRangeFrom(x, y, tx, ty) then
                    local distPlayer = math.abs(px - x) + math.abs(py - y)
                    local distTarget = math.abs(tx - x) + math.abs(ty - y)
                    local score = distPlayer * 10 + distTarget

                    if score < bestScore then
                        bestScore = score
                        bestX = x
                        bestY = y
                    end
                end
            end
        end
    end

    return bestX, bestY
end


-- ===== PATH RANGE AMAN + REJOIN =====
function safeMoveToPlantRange(tx, ty, targetWorld)
    waitPingStable()

    if targetWorld and not inWorld(targetWorld) then
        warp(targetWorld)
        Sleep(800)
    end

    if inPlantRange(tx, ty) then
        return true
    end

    local sx, sy = findStandTileForTarget(tx, ty)
    if not sx or not sy then
        LogToConsole("Tidak ada spot berdiri valid untuk target " .. tx .. "," .. ty)
        return false
    end

    FindPath(sx, sy, 400)
    Sleep(PATH_DELAY)
    waitPingStable()

    if inPlantRange(tx, ty) then
        return true
    end

    LogToConsole("FindPath range gagal ke target " .. tx .. "," .. ty .. " -> rejoin")

    if targetWorld then
        rejoinWorld(targetWorld)
        Sleep(800)
    end

    waitPingStable()

    if not inPlantRange(tx, ty) then
        sx, sy = findStandTileForTarget(tx, ty)
        if sx and sy then
            FindPath(sx, sy, 400)
            Sleep(PATH_DELAY)
            waitPingStable()
        end
    end

    return inPlantRange(tx, ty)
end


-- ===== CEK TILE TERISI =====
function waitPlaced(x, y)
    local tries = 0

    while tries < 8 do
        waitPingStable()
        Sleep(PLACE_DELAY)

        local t = GetTile(x, y)
        if t and t.fg ~= 0 then
            return true
        end

        tries = tries + 1
    end

    return false
end


-- ===== PLACE =====
function place(x, y, id)
    waitPingStable()

    if not inPlantRange(x, y) then
        local moved = safeMoveToPlantRange(x, y, worldFarm)
        if not moved then return false end
    end

    local me = GetLocal()
    if not me then return false end

    faceTile(x)
    Sleep(50)
    waitPingStable()

    me = GetLocal()
    if not me then return false end

    local px = math.floor(me.pos.x / 32)
    local state = 16
    if x < px then
        state = 48
    end

    SendPacketRaw(false, {
        type = 3,
        state = state,
        value = id,
        px = x,
        py = y,
        x = me.pos.x,
        y = me.pos.y
    })

    return waitPlaced(x, y)
end


-- ===== STATUS TILE =====
function isLeftoverTile(x, y)
    local t = GetTile(x, y)
    if not t then return false end
    return t.fg == seedA or t.fg == seedB
end

function isIncompleteTile(x, y)
    if isLeftoverTile(x, y) then
        return true
    end

    if canPlant(x, y) then
        return true
    end

    return false
end


-- ===== CEK BARIS MASIH PERLU DIPROSES =====
function rowNeedsFix(y)
    local w = GetWorld()
    if not w then return false end

    for x = 0, w.width - 1 do
        if isIncompleteTile(x, y) then
            return true
        end
    end

    return false
end


-- ===== FIND FLOATING TERDEKAT =====
function findNearestObject(id)
    local objs = GetObjectList()
    local me = GetLocal()
    if not me or not objs then return nil, nil end

    local best = 999999
    local bx, by = nil, nil

    local px = me.pos.x
    local py = me.pos.y

    for _, obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x - px)^2 + (obj.pos.y - py)^2)

            if dist < best then
                best = dist
                bx = math.floor(obj.pos.x / 32)
                by = math.floor(obj.pos.y / 32)
            end
        end
    end

    return bx, by
end


-- ===== TAKE SEED FLOATING =====
function takeSeedID(id)
    waitPingStable()

    local x, y = findNearestObject(id)
    if x and y then
        local moved = safeMoveToPlantRange(x, y, worldTake)
        if not moved then
            return false
        end

        Sleep(150)
        waitPingStable()

        SendPacket(2, "action|take")
        Sleep(TAKE_DELAY)
        return true
    end

    return false
end


-- ===== SPLICE =====
function splice(x, y)
    if not inWorld(worldFarm) then
        warp(worldFarm)
        Sleep(700)
    end

    waitPingStable()

    if not safeMoveToPlantRange(x, y, worldFarm) then
        LogToConsole("Gagal masuk range splice: " .. x .. "," .. y)
        return false
    end

    waitPingStable()

    local t = GetTile(x, y)
    if not t then return false end

    -- kosong valid -> place seedA lalu seedB
    if t.fg == 0 then
        if not canPlant(x, y) then
            return false
        end

        if inv(seedA) > 0 then
            if not place(x, y, seedA) then
                return false
            end
            Sleep(delay)
        else
            return false
        end

        waitPingStable()
        t = GetTile(x, y)
        if not t then return false end

        if (t.fg == seedA or t.fg == seedB) and inv(seedB) > 0 then
            place(x, y, seedB)
            Sleep(delay)
        end

        return true
    end

    -- kalau ada leftover seed, sempurnakan splice
    if t.fg == seedA or t.fg == seedB then
        if inv(seedA) > 0 then
            place(x, y, seedA)
            Sleep(delay)
        end

        waitPingStable()

        if inv(seedB) > 0 then
            place(x, y, seedB)
            Sleep(delay)
        end

        return true
    end

    return false
end


-- ===== AMBIL SEED =====
function ambilSeed()
    LogToConsole("Seed habis -> ke TAKE")

    warp(worldTake)
    Sleep(700)

    while inv(seedA) == 0 or inv(seedB) == 0 do
        waitPingStable()

        if not inWorld(worldTake) then
            warp(worldTake)
            Sleep(700)
        end

        if inv(seedA) == 0 then
            takeSeedID(seedA)
        end

        if inv(seedB) == 0 then
            takeSeedID(seedB)
        end

        Sleep(250)
    end

    LogToConsole("Seed dapat -> balik FARM")

    warp(worldFarm)
    Sleep(1000)

    while not inWorld(worldFarm) do
        LogToConsole("Belum masuk FARM -> retry")
        warp(worldFarm)
        Sleep(1000)
    end

    waitPingStable()
    spliceLeftover()
end

function cekSeedSmart()
    if inv(seedA) == 0 or inv(seedB) == 0 then
        ambilSeed()
    end
end


-- ===== SPLICE LEFTOVER PER BARIS =====
function processRowLeftover(y)
    local w = GetWorld()
    if not w then return false end

    if not rowNeedsFix(y) then
        return false
    end

    local didSomething = false
    local xs, xe, step = 0, w.width - 1, 1

    if y % 2 == 1 then
        xs, xe, step = w.width - 1, 0, -1
    end

    local x = xs
    while (step == 1 and x <= xe) or (step == -1 and x >= xe) do
        waitPingStable()

        if not inWorld(worldFarm) then
            warp(worldFarm)
            Sleep(700)
        end

        cekSeedSmart()

        local t = GetTile(x, y)
        if t then
            if t.fg == seedA or t.fg == seedB then
                if splice(x, y) then
                    didSomething = true
                end
            elseif t.fg == 0 and canPlant(x, y) then
                if splice(x, y) then
                    didSomething = true
                end
            end
        end

        x = x + step
    end

    return didSomething
end


-- ===== SPLICE LEFTOVER =====
function spliceLeftover()
    if not inWorld(worldFarm) then
        warp(worldFarm)
        Sleep(700)
    end

    local w = GetWorld()
    if not w then return false end

    local found = false

    for pass = 1, 3 do
        local didSomething = false

        for y = 0, w.height - 1 do
            waitPingStable()

            if not inWorld(worldFarm) then
                warp(worldFarm)
                Sleep(700)
                w = GetWorld()
                if not w then return found end
            end

            if rowNeedsFix(y) then
                LogToConsole("Fix row " .. y)
                if processRowLeftover(y) then
                    didSomething = true
                    found = true
                end
            end
        end

        if not didSomething then
            break
        end
    end

    return found
end


-- ===== SPLICE PER ROW =====
function spliceRow(y)
    local w = GetWorld()
    if not w then return end

    if not rowNeedsFix(y) then
        return
    end

    local xs, xe, step = 0, w.width - 1, 1
    if y % 2 == 1 then
        xs, xe, step = w.width - 1, 0, -1
    end

    local x = xs

    while (step == 1 and x <= xe) or (step == -1 and x >= xe) do
        waitPingStable()
        cekSeedSmart()

        if not inWorld(worldFarm) then
            warp(worldFarm)
            Sleep(700)
        end

        local t = GetTile(x, y)

        if t and (t.fg == seedA or t.fg == seedB) then
            splice(x, y)
        elseif canPlant(x, y) then
            splice(x, y)
        end

        x = x + step
    end
end


-- ===== MAIN =====
RunThread(function()
    warp(worldFarm)
    Sleep(1000)

    while true do
        waitPingStable()

        if not inWorld(worldFarm) then
            warp(worldFarm)
            Sleep(1000)
        end

        cekSeedSmart()
        spliceLeftover()

        local w = GetWorld()
        if w then
            for y = 0, w.height - 1 do
                waitPingStable()

                if not inWorld(worldFarm) then
                    warp(worldFarm)
                    Sleep(1000)
                end

                if rowNeedsFix(y) then
                    spliceRow(y)
                end
            end
        end

        LogToConsole("1 cycle selesai -> ulangi")
        Sleep(LOOP_DELAY)
    end
end)
