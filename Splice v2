
--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 150  -- dikurangi dari 150

local worldFarms = {
"njdoJ|abangku1",
"vujxB|abangku1",
"vujxC|abangku1",
"vujxG|abangku1",
"vujxL|abangku1",
"vujxM|abangku1",
"vujxN|abangku1",
}
local worldTake = "Savekubreak|abangku1"

local PING_LIMIT = 500
--===============================


-- ===== CEK PING =====
function waitPingStable()
    while GetClient().ping > PING_LIMIT do
        LogToConsole("Ping tinggi ("..GetClient().ping..") → menunggu")
        Sleep(300)
    end
end


-- ===== POSISI TILE PLAYER =====
function getPosTile()
    return math.floor(GetLocal().pos.x/32),
           math.floor(GetLocal().pos.y/32)
end


-- ===== HADAP TILE =====
function faceTile(x)
    local px = math.floor(GetLocal().pos.x/32)
    if x > px then
        SendPacketRaw(false,{type=0,state=16})
    elseif x < px then
        SendPacketRaw(false,{type=0,state=48})
    end
end


-- ===== INVENTORY =====
function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end


-- ===== WARP =====
function warp(world)
    local name = world:match("^([^|]+)") -- ambil nama sebelum "|"
    if GetWorld().name ~= name:upper() then
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(5000)
    end
end


-- ===== CEK TILE SUDAH KE-PLACE =====
function waitPlaced(x,y)
    for i = 1,8 do
        local t = GetTile(x,y)
        if t and t.fg ~= 0 then return true end
        Sleep(80)
    end
    return false
end


-- ===== PLACE =====
function place(x,y,id)
    waitPingStable()
    faceTile(x)
    Sleep(60)
    SendPacketRaw(false,{
        type  = 3,
        value = id,
        px    = x,
        py    = y,
        x     = GetLocal().pos.x,
        y     = GetLocal().pos.y
    })
    Sleep(30)
end


-- ===== MOVE GESER JIKA GAGAL TAKE =====
function moveAdjust(x, y)
    -- coba geser kanan dulu, lalu kiri
    local offsets = {1, -1, 2, -2}
    for _, ox in ipairs(offsets) do
        FindPath(x + ox, y, 400)
        Sleep(200)
        SendPacket(2,"action|take")
        Sleep(350)
        -- jika sudah dapat seed, berhenti geser
        if inv(seedA) > 0 and inv(seedB) > 0 then return end
    end
end


-- ===== TAKE SEED =====
function takeSeedID(id)
    waitPingStable()

    local function findObj()
        local objs = GetObjectList()
        local best = 99999
        local bx, by = nil, nil
        local px = GetLocal().pos.x
        local py = GetLocal().pos.y
        for _, obj in pairs(objs) do
            if obj.id == id then
                local dist = math.sqrt((obj.pos.x-px)^2 + (obj.pos.y-py)^2)
                if dist < best then
                    best = dist
                    bx = math.floor(obj.pos.x/32)
                    by = math.floor(obj.pos.y/32)
                end
            end
        end
        return bx, by
    end

    local x, y = findObj()
    if not x then return end

    FindPath(x, y, 400)
    Sleep(200)

    SendPacket(2,"action|take")
    Sleep(350)

    -- Jika masih 0 setelah take pertama → coba geser
    if inv(id) == 0 then
        moveAdjust(x, y)
    end
end


-- ===== AMBIL SEED =====
function ambilSeed()
    LogToConsole("Seed habis → ke TAKE world")
    warp(worldTake)
    Sleep(800)

    local attempts = 0
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(250)
        attempts = attempts + 1
        if attempts > 30 then
            LogToConsole("Gagal ambil seed setelah 30x, skip")
            break
        end
    end

    LogToConsole("Seed dapat → balik FARM")
end


function cekSeedSmart(worldFarm)
    if inv(seedA) == 0 or inv(seedB) == 0 then
        ambilSeed()
        warp(worldFarm)
        Sleep(800)
    end
end


-- ===== CEK TANAM =====
function canPlant(x,y)
    local t = GetTile(x,y)
    local b = GetTile(x,y+1)
    if not t or not b then return false end
    if t.fg ~= 0 then return false end
    return b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end


-- ===== SPLICE (OPTIMIZED) =====
function splice(x, y)
    waitPingStable()

    local px, py = getPosTile()
    local dist = math.abs(px - x) + math.abs(py - y)

    if dist > 0 then
        FindPath(x, y, 400)
        -- tunggu lebih singkat tergantung jarak
        Sleep(dist > 5 and 220 or 130)
    end

    if inv(seedA) > 0 then
        place(x, y, seedA)
        waitPlaced(x, y)
        Sleep(delay)
    end

    if inv(seedB) > 0 then
        place(x, y, seedB)
        waitPlaced(x, y)
        Sleep(delay)
    end
end


-- ===== SPLICE LEFTOVER =====
function spliceLeftover(worldFarm)
    local w = GetWorld()
    for y = 0, w.height-1 do
        for x = 0, w.width-1 do
            local t = GetTile(x,y)
            if t and (t.fg == seedA or t.fg == seedB) then
                cekSeedSmart(worldFarm)
                splice(x,y)
            end
        end
    end
end


-- ===== CEK WORLD SUDAH SELESAI SEMUA =====
function isWorldDone()
    local w = GetWorld()
    for y = 0, w.height-1 do
        for x = 0, w.width-1 do
            if canPlant(x, y) then return false end
            local t = GetTile(x,y)
            if t and (t.fg == seedA or t.fg == seedB) then return false end
        end
    end
    return true
end


-- ===== SPLICE PER ROW =====
function spliceRow(y, worldFarm)
    local w = GetWorld()
    local xs, xe, step = 0, w.width-1, 1
    if y % 2 == 1 then xs, xe, step = w.width-1, 0, -1 end

    local x = xs
    while (step==1 and x<=xe) or (step==-1 and x>=xe) do

        cekSeedSmart(worldFarm)

        local t = GetTile(x,y)
        if t and (t.fg == seedA or t.fg == seedB) then
            splice(x,y)
        elseif canPlant(x,y) then
            splice(x,y)
        end

        x = x + step
    end
end


-- ===== PROSES 1 WORLD FARM =====
function processFarm(worldFarm)
    LogToConsole("Mulai farm: "..worldFarm)
    warp(worldFarm)
    Sleep(1000)

    cekSeedSmart(worldFarm)
    spliceLeftover(worldFarm)

    local w = GetWorld()
    for y = 0, w.height-1 do
        spliceRow(y, worldFarm)
    end

    -- Setelah 1 pass, cek ulang supaya tidak ada seed tertinggal
    LogToConsole("Pass 1 selesai → cek ulang leftover")
    spliceLeftover(worldFarm)

    if isWorldDone() then
        LogToConsole("World "..worldFarm.." SELESAI semua ✓")
        return true
    end

    return false
end


-- ===== MAIN =====
RunThread(function()

    while true do

        local allDone = true

        for _, farmWorld in ipairs(worldFarms) do

            local done = processFarm(farmWorld)

            if not done then
                allDone = false
            end
        end

        if allDone then
            LogToConsole("Semua world selesai → berhenti.")
            break
        end

        LogToConsole("Ada world belum selesai → ulang cycle")
        Sleep(500)
    end

end)
