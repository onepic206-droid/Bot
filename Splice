--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 130 
local RANGE_PIXEL = 400 -- Jarak maksimal sebelum panggil FindPath

local worldTake = "Savekubreak|abangku1"
local worldFarm = "WFJEW|b18"
--===============================

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function getPosTile()
    return math.floor(GetLocal().pos.x/32), math.floor(GetLocal().pos.y/32)
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(6000)
    end
end

-- ===== PLACE RAW + ANIMASI =====
function place(x, y, id)
    local px = GetLocal().pos.x
    local py = GetLocal().pos.y

    -- Orientasi (Facing)
    SendPacketRaw(false, {
        type = 0,
        x = px, y = py,
        state = 48,
        tilex = x, tiley = y
    })

    -- Action Build
    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x, py = y,
        x = px, y = py,
        state = 16,
        tilex = x, tiley = y
    })

    -- Animasi Visual
    SendPacketRaw(false, {
        type = 0,
        value = id,
        px = x, py = y,
        x = px, y = py,
        state = 3120,
        tilex = x, tiley = y
    })
end

-- ===== SPLICE DENGAN JARAK JANGKAUAN =====
function splice(x, y)
    local localPos = GetLocal().pos
    local targetX = x * 32
    local targetY = y * 32

    -- Hitung jarak dalam pixel (Euclidean distance)
    local dist = math.sqrt((targetX - localPos.x)^2 + (targetY - localPos.y)^2)

    -- Jika jarak lebih dari 400 pixel, baru jalan (FindPath)
    if dist > RANGE_PIXEL then
        FindPath(x, y)
        Sleep(300) -- Beri waktu bot untuk bergerak
    end

    if inv(seedA) > 0 then
        place(x, y, seedA)
        Sleep(delay)
    end

    if inv(seedB) > 0 then
        place(x, y, seedB)
        Sleep(delay)
    end
end

function canPlant(x, y)
    local t = GetTile(x, y)
    local b = GetTile(x, y + 1)
    if not t or not b then return false end
    return t.fg == 0 and b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end

function findNearestObject(id)
    local objs = GetObjectList()
    local best = 999999
    local bx, by = nil, nil
    local px, py = GetLocal().pos.x, GetLocal().pos.y
    for _, obj in pairs(objs) do
        if obj.id == id then
            local dist = math.sqrt((obj.pos.x-px)^2 + (obj.pos.y-py)^2)
            if dist < best then
                best = dist
                bx, by = math.floor(obj.pos.x/32), math.floor(obj.pos.y/32)
            end
        end
    end
    return bx, by
end

function takeSeedID(id)
    local x, y = findNearestObject(id)
    if x then
        FindPath(x, y)
        Sleep(400)
        SendPacket(2, "action|take")
        Sleep(500)
    end
end

function ambilSeed()
    LogToConsole("Seed habis -> Ambil stok")
    warp(worldTake)
    Sleep(1500)
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(400)
    end
    LogToConsole("Seed OK -> Balik Farm")
    warp(worldFarm)
    Sleep(1500)
end

function cekSeedSmart()
    if inv(seedA) == 0 or inv(seedB) == 0 then ambilSeed() end
end

function spliceLeftover()
    local w = GetWorld()
    for y = 0, w.height - 1 do
        for x = 0, w.width - 1 do
            local t = GetTile(x, y)
            if t and (t.fg == seedA or t.fg == seedB) then
                splice(x, y)
            end
        end
    end
end

function spliceRow(y)
    local w = GetWorld()
    local xs, xe, step = 0, w.width - 1, 1
    if y % 2 == 1 then xs, xe, step = w.width - 1, 0, -1 end

    local x = xs
    while (step == 1 and x <= xe) or (step == -1 and x >= xe) do
        if not GetWorld().name then break end
        
        local t = GetTile(x, y)
        -- Cek apakah tile tersebut perlu di-splice (sudah ada satu seed atau masih kosong tapi bisa ditanam)
        if (t and (t.fg == seedA or t.fg == seedB)) or canPlant(x, y) then
            cekSeedSmart()
            splice(x, y)
        end
        x = x + step
    end
end

-- ===== MAIN THREAD =====
RunThread(function()
    warp(worldFarm)
    Sleep(1500)

    cekSeedSmart()
    
    -- Selesaikan sisa-sisa seed yang terpasang sendirian
    spliceLeftover()

    local w = GetWorld()
    for y = 0, w.height - 1 do
        if not GetWorld().name then break end
        spliceRow(y)
    end

    LogToConsole("WORLD SELESAI - SCRIPT OFF")
    Terminate() 
end)
