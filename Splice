--=========== CONFIG ===========
local seedA = 613
local seedB = 13
local delay = 100 

local worldTake = "Savekubreak|abangku1"
local worldFarm = "VVRCL|b18"
local worldSave = "DUNIA_SIMPAN_SEED" -- Ganti dengan world tujuan drop
--===============================

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(6000)
    end
end

function getFg(x,y)
    local t = GetTile(x,y)
    if t then return t.fg end
    return -1
end

-- ===== SMOOTH MOVE & PLACE =====
function place(x, y, id)
    -- Range 400 untuk pencarian jalan lebih luas
    FindPath(x, y, 400) 
    
    local px = GetLocal().pos.x
    local py = GetLocal().pos.y
    
    -- Face Direction: 48 (Kanan), 0 (Kiri)
    local state = ((x * 32) > px) and 48 or 0

    -- Kirim Paket Gerak untuk update Facing (Arah)
    SendPacketRaw(false, {
        type = 0,
        x = px,
        y = py,
        state = state
    })

    -- Paket Tanam (State 3120 + Paket Tanam)
    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = px,
        y = py,
        state = 3120 
    })
end

function splice(x, y)
    -- Tanam Seed A
    if inv(seedA) > 0 and getFg(x,y) == 0 then
        place(x, y, seedA)
        local t = 0
        while getFg(x,y) ~= seedA and t < 15 do
            Sleep(80)
            t = t + 1
        end
    end

    -- Tanam Seed B
    if inv(seedB) > 0 and getFg(x,y) == seedA then
        place(x, y, seedB)
        local t = 0
        while getFg(x,y) == seedA and t < 15 do
            Sleep(80)
            t = t + 1
        end
    end
    
    Sleep(delay)
end

-- ===== AUTO DROP SEED (Maks 200) =====
function cekAndDrop()
    -- Ganti ID_HASIL_SPLICE dengan ID seed hasil campuran Anda
    local seedHasil = 0 -- ISI DISINI (Contoh: 123)
    
    if inv(seedHasil) >= 200 then
        LogToConsole("Seed mencapai 200! Pergi ke world simpan...")
        warp(worldSave)
        Sleep(1000)
        -- Logika drop (Opsional: Cari posisi kosong dulu)
        SendPacket(2, "action|drop\nitemID|" .. seedHasil)
        SendPacket(2, "dialog_return|drop_item\nitemID|" .. seedHasil .. "|\ncount|" .. inv(seedHasil))
        Sleep(1000)
        warp(worldFarm)
    end
end

-- ===== LOGIKA PENDUKUNG =====

function canPlant(x,y)
    local t, b = GetTile(x,y), GetTile(x,y+1)
    if not t or not b then return false end
    -- Cek tile atas kosong (0) dan tile bawah adalah tanah/block solid
    return t.fg == 0 and b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end

function takeSeedID(id)
    local objs = GetObjectList()
    for _, obj in pairs(objs) do
        if obj.id == id then
            FindPath(math.floor(obj.pos.x/32), math.floor(obj.pos.y/32), 400)
            Sleep(200)
            SendPacket(2,"action|take")
            Sleep(300)
            return
        end
    end
end

function ambilSeed()
    LogToConsole("Kurang material, mengambil di: " .. worldTake)
    warp(worldTake)
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(200)
    end
    warp(worldFarm)
end

-- ===== MAIN LOOP =====
RunThread(function()
    warp(worldFarm)
    while true do
        local w = GetWorld()
        local workFound = false
        
        for y = 0, w.height-1 do
            -- Snake movement (kiri-kanan-kanan-kiri)
            local xs, xe, step = 0, w.width-1, 1
            if y % 2 == 1 then xs, xe, step = w.width-1, 0, -1 end
            
            for x = xs, xe, step do
                local fg = getFg(x,y)
                
                -- Pengecekan Seed
                if inv(seedA) == 0 or inv(seedB) == 0 then ambilSeed() end
                
                -- Cek apakah butuh di-splice atau ditanam baru
                if fg == seedA or fg == seedB or canPlant(x,y) then
                    workFound = true
                    splice(x,y)
                    -- cekAndDrop() -- Aktifkan jika ingin cek jumlah seed setiap tanam
                end
            end
        end

        if not workFound then
            LogToConsole("Selesai! Tidak ada lahan tersisa.")
            break
        end
        Sleep(1000)
    end
end)
