--=========== CONFIG ===========
local seedA = 107
local seedB = 169
local delay = 200

local worldTake = "Savekubreak|abangku1"
local worldFarm = "VVRCL|b18"
--===============================

function inv(id)
    for _, item in pairs(GetInventory()) do
        if item.id == id then return item.amount end
    end
    return 0
end

function warp(world)
    if GetWorld().name ~= world:upper() then
        SendPacket(3,"action|join_request\nname|"..world)
        Sleep(6000)
    end
end

function getFg(x,y)
    local t = GetTile(x,y)
    if t then return t.fg end
    return -1
end

-- ===== SMOOTH MOVE & PLACE (DENGAN ANIMASI) =====
function place(x, y, id)
    -- Bergerak ke posisi target dengan range 400
    FindPath(x, y, 400) 
    
    local px = GetLocal().pos.x
    local py = GetLocal().pos.y
    
    -- Logika Hadap: 48 (Kanan), 0 (Kiri)
    local state = ((x * 32) > px) and 48 or 0

    -- Kirim paket update arah karakter agar tidak kaku
    SendPacketRaw(false, {
        type = 0,
        x = px,
        y = py,
        state = state
    })

    -- Paket Tanam (State 3120 untuk animasi tangan meletakkan)
    SendPacketRaw(false, {
        type = 3,
        value = id,
        px = x,
        py = y,
        x = px,
        y = py,
        state = 3120 
    })
end

function splice(x, y)
    -- Tanam Seed A
    if inv(seedA) > 0 and getFg(x,y) == 0 then
        place(x, y, seedA)
        local t = 0
        while getFg(x,y) ~= seedA and t < 15 do
            Sleep(80)
            t = t + 1
        end
    end

    -- Tanam Seed B (Splicing)
    if inv(seedB) > 0 and getFg(x,y) == seedA then
        place(x, y, seedB)
        local t = 0
        while getFg(x,y) == seedA and t < 15 do
            Sleep(80)
            t = t + 1
        end
    end
    
    Sleep(delay)
end

-- ===== LOGIKA PENGAMBILAN MATERIAL =====

function canPlant(x,y)
    local t, b = GetTile(x,y), GetTile(x,y+1)
    if not t or not b then return false end
    return t.fg == 0 and b.fg ~= 0 and b.fg % 2 == 0 and b.fg ~= 6
end

function takeSeedID(id)
    local objs = GetObjectList()
    for _, obj in pairs(objs) do
        if obj.id == id then
            FindPath(math.floor(obj.pos.x/32), math.floor(obj.pos.y/32), 400)
            Sleep(250)
            SendPacket(2,"action|take")
            Sleep(350)
            return
        end
    end
end

function ambilSeed()
    LogToConsole("Seed habis, mengambil ke: " .. worldTake)
    warp(worldTake)
    while inv(seedA) == 0 or inv(seedB) == 0 do
        if inv(seedA) == 0 then takeSeedID(seedA) end
        if inv(seedB) == 0 then takeSeedID(seedB) end
        Sleep(200)
    end
    LogToConsole("Seed siap, kembali ke: " .. worldFarm)
    warp(worldFarm)
end

-- ===== MAIN THREAD =====
RunThread(function()
    warp(worldFarm)
    while true do
        local w = GetWorld()
        local workFound = false
        
        for y = 0, w.height-1 do
            -- Snake movement row
            local xs, xe, step = 0, w.width-1, 1
            if y % 2 == 1 then xs, xe, step = w.width-1, 0, -1 end
            
            for x = xs, xe, step do
                local fg = getFg(x,y)
                
                -- Cek stok sebelum kerja
                if inv(seedA) == 0 or inv(seedB) == 0 then 
                    ambilSeed() 
                end
                
                -- Jika butuh splice atau bisa ditanam
                if fg == seedA or fg == seedB or canPlant(x,y) then
                    workFound = true
                    splice(x,y)
                end
            end
        end

        if not workFound then
            LogToConsole("Semua lahan sudah penuh ditanam!")
            break
        end
        Sleep(1000)
    end
end)
